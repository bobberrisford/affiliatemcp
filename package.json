{
  "name": "affiliate-networks-mcp",
  "version": "0.15.0",
  "description": "Bring affiliate-network data to Claude or Codex through a local stdio MCP server. 80+ publisher and advertiser-side adapters, most experimental. Local-only, bring your own keys.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobberrisford/affiliatemcp.git"
  },
  "homepage": "https://github.com/bobberrisford/affiliatemcp#readme",
  "bugs": {
    "url": "https://github.com/bobberrisford/affiliatemcp/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "affiliate-networks-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "templates",
    "skills",
    ".claude-plugin",
    "README.md",
    "PRIVACY.md",
    "LICENCE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:mcpb": "npm run build && tsx scripts/build-mcpb.ts",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.dev.json",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "lint:design": "npx --yes oxlint@latest -c design-system/adherence.oxlintrc.json desktop/renderer || true",
    "check:change": "tsx scripts/check-change.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "echo \"test:live placeholder — implemented in a later chunk\" && exit 0",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "verify:mcpb": "npm run build:mcpb && node scripts/smoke-mcp.mjs --entry .artifacts/mcpb/server/index.cjs --server-only",
    "scaffold:network": "tsx scripts/scaffold-network.ts",
    "validate:network": "tsx scripts/validate-network-json.ts",
    "generate:readme": "tsx scripts/generate-readme-table.ts",
    "generate:report": "tsx scripts/generate-report.ts",
    "generate:report-image": "tsx scripts/generate-report-image.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  }
}
