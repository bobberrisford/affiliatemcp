# affiliate-mcp credentials — copy to ~/.affiliate-mcp/.env
# All values are loaded by src/shared/config.ts.
# Never commit a real .env file. The CLI wizard writes this for you on first run.

# Optional persistent result cache. Off unless explicitly set to on.
# Stores selected API results locally under ~/.affiliate-mcp/cache/ with
# owner-only permissions. On a shared machine where you cannot rely on file
# permissions, leave this off. See PRIVACY.md before enabling.
# AFFILIATE_MCP_CACHE=on

# Optional update check. On by default: once per day the server reads the
# package's latest published version from the npm registry to tell you when a
# newer release exists. The request is anonymous — no credentials, account
# identifiers, or affiliate data. Set to 0/false/no/off to disable. See
# PRIVACY.md.
# AFFILIATE_MCP_UPDATE_CHECK=0

# Optional silent auto-apply. Off by default. When on (1/true/yes/on), the
# server updates itself on launch for npm/npx installs by installing the latest
# version globally, so the next launch runs it. It never applies on host-managed
# surfaces (.mcpb / desktop bundle) and only applies a release it has known about
# for at least AFFILIATE_MCP_AUTO_UPDATE_MIN_AGE_HOURS (default 24). Toggle with
# `affiliate-networks-mcp update enable|disable`.
# AFFILIATE_MCP_AUTO_UPDATE=1
# AFFILIATE_MCP_AUTO_UPDATE_MIN_AGE_HOURS=24

# Optional tool-result size budget in bytes. Claude clients reject MCP tool
# results over roughly 1 MB, so the server keeps every response under this
# budget: large results are serialised compactly, and a result that still
# exceeds the budget is truncated honestly (lists) or refused with a
# result_too_large payload instead of failing opaquely client-side.
# Default 800000. Lower it if your client enforces a smaller cap.
# AFFILIATE_MCP_MAX_RESULT_BYTES=800000

# Awin
AWIN_API_TOKEN=
AWIN_PUBLISHER_ID=

# CJ (Commission Junction)
CJ_PERSONAL_ACCESS_TOKEN=
CJ_COMPANY_ID=
CJ_WEBSITE_ID=

# Impact.com
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=

# Rakuten Advertising
RAKUTEN_CLIENT_ID=
RAKUTEN_CLIENT_SECRET=
RAKUTEN_REFRESH_TOKEN=
RAKUTEN_SCOPE=

# eBay Partner Network
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_CAMPAIGN_ID=
# Optional overrides:
# EBAY_MARKETPLACE_ID=EBAY_GB        # default marketplace for the X-EBAY-C-MARKETPLACE-ID header
# EBAY_OAUTH_SCOPE=                  # override the default api_scope used for token exchange
# EBAY_ROTATION_ID=711-53200-19255-0 # rover rotation segment for tracking link construction
# EBAY_BASE_URL=                     # point at https://api.sandbox.ebay.com for testing
# EBAY_TOKEN_URL=                    # override the OAuth token endpoint (sandbox / test seam)

# Hosted MCP transport (workstream slice H4, `affiliate-networks-mcp hosted-transport`).
# Operator-only: these configure the multi-tenant Node service that fronts the
# hosted `hosted/` Worker, not a per-network credential. Irrelevant to the
# default local stdio server. See docs/product/hosted-mvp-workstream.md.
# HOSTED_AUTH_URL=                          # hosted Worker base URL, used for POST /auth/session/verify and GET /billing/entitlement
# HOSTED_VAULT_URL=                         # hosted Worker base URL, used for GET /vault/credentials/:network/reveal and GET /vault/credentials
# HOSTED_TRANSPORT_PORT=8787                # port the streamable-HTTP MCP endpoint listens on
# HOSTED_RATE_LIMIT_CAPACITY=60             # per-user token-bucket burst size (tool calls); Pro tier, and the Solo default
# HOSTED_RATE_LIMIT_REFILL_PER_SECOND=1     # per-user token-bucket sustained refill rate; Pro tier, and the Solo default
# HOSTED_RATE_LIMIT_CAPACITY_SOLO=          # Solo-tier override (H6); falls back to HOSTED_RATE_LIMIT_CAPACITY when unset
# HOSTED_RATE_LIMIT_REFILL_PER_SECOND_SOLO= # Solo-tier override (H6); falls back to HOSTED_RATE_LIMIT_REFILL_PER_SECOND when unset
# HOSTED_MAX_TOKEN_LIFETIME_SECONDS=        # OAuth bearer-migration cutover lever; unset = dual-accept (legacy bearers + OAuth access tokens), set ~7200 to reject long-lived pasted bearers

# Digest-compose service (workstream slice H6, `affiliate-networks-mcp hosted-digest`).
# Operator-only: a long-running HTTP service the hosted Worker's Cron Trigger
# calls once per subscriber per digest type; the Worker owns the schedule,
# roster, tokens, and email send. This service holds no roster, no emails,
# and no credential of its own — every read it performs is authorised by the
# Worker-minted, per-user, digest-scoped session token on each request.
# Reuses HOSTED_VAULT_URL above. See src/hosted-digest/index.ts.
# DIGEST_SERVICE_PORT=8788                  # port the compose service listens on
# DIGEST_COMPOSE_SECRET=                    # optional doorbell the Worker sends as x-compose-auth; grants no data access

# Desktop entitlement client (src/core/entitlement.ts).
# AFFILIATE_MCP_ISSUER_URL=                 # override the entitlement issuer origin; defaults to https://billing.agenticaffiliate.ai
