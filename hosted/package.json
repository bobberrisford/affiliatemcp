{
  "name": "affiliate-mcp-hosted",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted-service Cloudflare Worker for affiliate-mcp (workstream slices H2-H3): email magic-link sign-in, Ed25519-signed session tokens, and an envelope-encrypted per-user credential vault.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen-keypair": "tsx scripts/gen-keypair.ts",
    "gen-vault-key": "tsx scripts/gen-vault-key.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  }
}
