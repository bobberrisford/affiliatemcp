{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/landing/**",
              "ui_kits/terminal/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Space Grotesk, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-2",
      "--accent-on",
      "--acid",
      "--acid-deep",
      "--bg",
      "--bg-invert",
      "--bg-panel",
      "--blue",
      "--blue-bright",
      "--blue-deep",
      "--fg",
      "--fg-invert",
      "--fg-invert-mut",
      "--fg-muted",
      "--font-display",
      "--font-mono",
      "--font-sans",
      "--hair",
      "--ink",
      "--ink-soft",
      "--lh-body",
      "--lh-snug",
      "--lh-tight",
      "--line",
      "--line-invert",
      "--line-strong",
      "--link",
      "--magenta",
      "--neg",
      "--paper",
      "--paper-2",
      "--pending",
      "--pos",
      "--pos-hi",
      "--r-0",
      "--r-pill",
      "--r-sm",
      "--r-xs",
      "--riso",
      "--rule",
